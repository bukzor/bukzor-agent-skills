#!/bin/bash
# Create new devlog entry with date-based auto-incrementing number

set -euo pipefail

onerror() {
  error="$?"
  echo >&2 "ERROR($error)"
  exit "$error"
}
trap onerror ERR

if (( ${DEBUG:-0} > 0 )); then
  set -x
fi

# Locate skeleton directory (before any -C cd, so a relative $0 still resolves)
HERE="$(cd "$(dirname "$0")"; pwd)"
SKILL_DIR="$(cd "$HERE/.." && pwd)"
SKELETON="$SKILL_DIR/skeleton"

DIR="."
DRY_RUN=0
TITLE=""
TITLE_SET=0
usage() {
  echo >&2 "Usage: llm-collab-devlog [-C <dir>] [-n|--dry-run] --title <title>"
  echo >&2 "       DATE=YYYY-MM-DD llm-collab-devlog ... --title <title>  (for backdating)"
  echo >&2 "       -C <dir>:      run as if invoked from <dir> (default: .)"
  echo >&2 "       --title:       entry title (required)"
  echo >&2 "       -n, --dry-run: print path without creating file"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -n|--dry-run) DRY_RUN=1; shift ;;
    -C)
      [ -n "${2:-}" ] || { echo >&2 "Error: -C requires an argument"; usage; exit 1; }
      DIR="$2"; shift 2 ;;
    --title)
      [ -n "${2:-}" ] || { echo >&2 "Error: --title requires an argument"; usage; exit 1; }
      TITLE="$2"; TITLE_SET=1; shift 2 ;;
    -*) echo >&2 "Unknown option: $1"; usage; exit 1 ;;
    *)
      echo >&2 "Error: unexpected argument '$1' -- positional args are not accepted"
      echo >&2 "       did you mean: -C '$1'  or  --title '$1' ?"
      usage; exit 1 ;;
  esac
done

if (( ! TITLE_SET )); then
  usage
  exit 1
fi

if [ ! -d "$DIR" ]; then
  echo >&2 "Error: -C target '$DIR' is not a directory"
  exit 1
fi
cd "$DIR"

# Migrate old location to new location if needed
if [ -d "docs/devlog" ]; then
  if [ -d "docs/dev/devlog" ]; then
    echo >&2 "Error: Both docs/devlog/ and docs/dev/devlog/ exist - manual resolution required"
    exit 1
  fi
  echo >&2 "⚠️  Found docs/devlog/ - migrating to docs/dev/devlog/"
  mkdir -p docs/dev
  if git mv docs/devlog docs/dev/devlog 2>/dev/null; then
    echo >&2 "✅ Migrated docs/devlog/ → docs/dev/devlog/ (git mv)"
  else
    mv docs/devlog docs/dev/devlog
    echo >&2 "✅ Migrated docs/devlog/ → docs/dev/devlog/ (mv)"
  fi
fi

if [ ! -d "docs/dev/devlog" ]; then
  echo >&2 "Error: docs/dev/devlog/ not found in $PWD"
  echo >&2 "If this is the right location, run: mkdir -p docs/dev/devlog && !!"
  exit 1
fi

DATE=${DATE:-$(date +%Y-%m-%d)}
LAST=$(find docs/dev/devlog -maxdepth 1 -name "$DATE-*" -print0 2>/dev/null | xargs -r0 ls -1t | sed -n '1p' || echo "")

if [ -z "$LAST" ]; then
  NUM="000"
else
  # Extract number after date prefix, handle leading zeros properly
  # Default to -1 if pattern doesn't match (so next becomes 000)
  NUM=$(basename "$LAST" | sed -E "s/^$DATE-([0-9]{3})-.*/\1/")
  if ! [[ "$NUM" =~ ^[0-9]+$ ]]; then
    NUM="-1"
  fi
  NUM=$(printf "%03d" $((10#$NUM + 1)))
fi

# Create slug from title
SLUG=$("$HERE/../../bin/claude-slug" "$TITLE")
FILE="docs/dev/devlog/$DATE-$NUM-$SLUG.md"

echo "$FILE"

if (( DRY_RUN )); then
  exit 0
fi

CONTENT=$(<"$SKELETON/docs/dev/devlog/YYYY-MM-DD-000-example-entry.md")
CONTENT=${CONTENT//YYYY-MM-DD/$DATE}
CONTENT=${CONTENT//TITLE/$TITLE}
printf '%s\n' "$CONTENT" > "$FILE"

echo >&2 "✅ Created"
