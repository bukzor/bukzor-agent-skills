#!/bin/bash
# Slugify text using Claude Code's own encoding scheme (reverse-engineered
# from ~/.claude/projects/ directory naming): every character that is not
# ASCII alnum becomes exactly one '-' -- no squeezing runs, no case
# folding, no path semantics (unlike claude-path, this never resolves
# '.'/'..'/trailing-slash -- pure text, safe for titles).
# Usage: claude-slug TEXT

set -euo pipefail

printf '%s' "$1" | perl -CSD -pe 's/[^A-Za-z0-9]/-/g'
echo
