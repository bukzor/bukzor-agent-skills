#!/bin/bash
# Ensure .claude/todo.md exists (idempotent)
# Prints path to stdout

set -euo pipefail

onerror() {
  error="$?"
  echo >&2 "ERROR($error)"
  exit "$error"
}
trap onerror ERR

if (( ${DEBUG:-0} > 0 )); then
  set -x
fi

# Locate skeleton directory (before any -C cd, so a relative $0 still resolves)
HERE="$(cd "$(dirname "$0")"; pwd)"
SKELETON="$HERE/../skeleton/.claude"

DIR="."
usage() {
  echo >&2 "Usage: llm-subtask-init [-C <dir>]"
  echo >&2 "       Ensure .claude/todo.md exists (idempotent)"
  echo >&2 "       -C <dir>: run as if invoked from <dir> (default: .)"
  echo >&2 "       Prints path to stdout"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -C)
      [ -n "${2:-}" ] || { echo >&2 "Error: -C requires an argument"; usage; exit 1; }
      DIR="$2"; shift 2 ;;
    -*) echo >&2 "Unknown option: $1"; usage; exit 1 ;;
    *)
      echo >&2 "Error: unexpected argument '$1' -- positional args are not accepted; use -C '$1'"
      usage; exit 1 ;;
  esac
done

if [ ! -d "$DIR" ]; then
  echo >&2 "Error: -C target '$DIR' is not a directory"
  exit 1
fi
cd "$DIR"

# Check .claude/ exists (signal we're in right place)
if [ ! -d ".claude" ]; then
  echo >&2 "Error: .claude/ not found in $PWD"
  echo >&2 "If this is the right location, run: mkdir -p .claude && !!"
  exit 1
fi

# Create todo.md (only if missing - contains user content)
if [ ! -f .claude/todo.md ]; then
  cp "$SKELETON/todo.md" .claude/todo.md
fi

# Create todo.kb/ with CLAUDE.md
mkdir -p .claude/todo.kb
cp "$SKELETON/todo.kb/CLAUDE.md" .claude/todo.kb/CLAUDE.md

# Create ideas.kb/ with CLAUDE.md
mkdir -p .claude/ideas.kb
cp "$SKELETON/ideas.kb/CLAUDE.md" .claude/ideas.kb/CLAUDE.md

echo "$PWD/.claude/todo.md"
