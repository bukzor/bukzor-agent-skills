#!/bin/bash
# Create new idea file with auto-incrementing number

set -euo pipefail

onerror() {
  error="$?"
  echo >&2 "ERROR($error)"
  exit "$error"
}
trap onerror ERR

if (( ${DEBUG:-0} > 0 )); then
  set -x
fi

# Locate skeleton directory (before any -C cd, so a relative $0 still resolves)
HERE="$(cd "$(dirname "$0")"; pwd)"
SKILL_DIR="$(cd "$HERE/.." && pwd)"
SKELETON="$SKILL_DIR/skeleton"

DIR="."
DRY_RUN=0
TITLE=""
TITLE_SET=0
usage() {
  echo >&2 "Usage: llm-subtask-idea [-C <dir>] [-n|--dry-run] --title <title>"
  echo >&2 "       DATE=YYYY-MM-DD llm-subtask-idea ... --title <title>  (for backdating)"
  echo >&2 "       -C <dir>:      run as if invoked from <dir> (default: .)"
  echo >&2 "       --title:       idea title (required)"
  echo >&2 "       -n, --dry-run: print path without creating file"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -n|--dry-run) DRY_RUN=1; shift ;;
    -C)
      [ -n "${2:-}" ] || { echo >&2 "Error: -C requires an argument"; usage; exit 1; }
      DIR="$2"; shift 2 ;;
    --title)
      [ -n "${2:-}" ] || { echo >&2 "Error: --title requires an argument"; usage; exit 1; }
      TITLE="$2"; TITLE_SET=1; shift 2 ;;
    -*) echo >&2 "Unknown option: $1"; usage; exit 1 ;;
    *)
      echo >&2 "Error: unexpected argument '$1' -- positional args are not accepted"
      echo >&2 "       did you mean: -C '$1'  or  --title '$1' ?"
      usage; exit 1 ;;
  esac
done

if (( ! TITLE_SET )); then
  usage
  exit 1
fi

if [ ! -d "$DIR" ]; then
  echo >&2 "Error: -C target '$DIR' is not a directory"
  exit 1
fi
cd "$DIR"

# Ensure we're in project root
if [ ! -d ".claude" ]; then
  echo >&2 "Error: .claude/ not found in $PWD"
  echo >&2 "If this is the right location, run: mkdir -p .claude/ideas.kb && !!"
  exit 1
fi

mkdir -p .claude/ideas.kb
cp "$SKELETON/.claude/ideas.kb/CLAUDE.md" .claude/ideas.kb/CLAUDE.md

DATE=${DATE:-$(date +%Y-%m-%d)}
LAST=$(find .claude/ideas.kb -maxdepth 1 -name "$DATE-*" -print0 2>/dev/null | xargs -r0 ls -1t | sed -n '1p' || echo "")

if [ -z "$LAST" ]; then
  NUM="000"
else
  # Extract number after date prefix, handle leading zeros properly
  NUM=$(basename "$LAST" | sed -E "s/^$DATE-([0-9]{3})-.*/\1/")
  NUM=$(printf "%03d" $((10#$NUM + 1)))
fi

# Create slug from title
SLUG=$("$HERE/../../bin/claude-slug" "$TITLE")
FILE=".claude/ideas.kb/$DATE-$NUM-$SLUG.md"

echo "$FILE"

if (( DRY_RUN )); then
  exit 0
fi

CONTENT=$(<"$SKELETON/.claude/ideas.kb/YYYY-MM-DD-000-example-idea.md")
CONTENT=${CONTENT//"Example Idea Title"/$TITLE}
CONTENT=${CONTENT//YYYY-MM-DD/$DATE}
printf '%s\n' "$CONTENT" > "$FILE"

echo >&2 "✅ Created"
